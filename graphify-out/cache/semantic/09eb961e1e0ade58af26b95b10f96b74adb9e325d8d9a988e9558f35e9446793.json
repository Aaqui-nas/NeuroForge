{"nodes": [{"id": "dev_phase2_pytorch_training_shape_inference", "label": "Shape Inference (Tensor Propagation)", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses topological sort (Kahn) to propagate shapes. Dimensions can be partially known (batch size = None). Uses Optional[int] for unknown dims. Propagation stops and raises error on incompatible shapes."}, {"id": "dev_phase2_pytorch_training_pytorch_codegen", "label": "PyTorch Code Generator (Graph \u2192 nn.Module)", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "String-based code generation (not AST) for human readability. Output is debuggable by the user. Generation must be deterministic: same graph \u2192 same code. ComponentNodes resolved recursively into separate nn.Module subclasses."}, {"id": "dev_phase2_pytorch_training_datasetconfig", "label": "DatasetConfig", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase2_pytorch_training_trainingconfig", "label": "TrainingConfig", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Configs must be serializable for versioning in phase 3. Validate coherence: e.g., BCE loss + non-sigmoid output \u2192 warning."}, {"id": "dev_phase2_pytorch_training_trainingworker", "label": "TrainingWorker (subprocess)", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runs in a separate subprocess to keep UI reactive. UI reads queue via QTimer every 100ms (non-blocking). Checkpoints saved by worker via torch.save. Monitor worker process via .is_alive() to handle crashes."}, {"id": "dev_phase2_pytorch_training_metricsemitter", "label": "MetricsEmitter", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase2_pytorch_training_trainingcontroller", "label": "TrainingController", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase2_pytorch_training_trainingmessage", "label": "TrainingMessage (IPC Queue)", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase2_pytorch_training_run", "label": "Run (Experiment Tracking)", "file_type": "concept", "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.6", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stored in SQLite (no ORM, stdlib sqlite3). Metrics kept in memory during run, flushed to DB in batches. Index on experiment_name and start_time for comparison queries."}], "edges": [{"source": "dev_phase2_pytorch_training_shape_inference", "target": "dev_phase1_project_graph_dfs_cycle_detection", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase2_pytorch_training.md", "source_location": "section 2.1 \u2014 cites Kahn algorithm from phase 1.4", "weight": 1.0}, {"source": "dev_phase2_pytorch_training_shape_inference", "target": "dev_phase1_project_graph