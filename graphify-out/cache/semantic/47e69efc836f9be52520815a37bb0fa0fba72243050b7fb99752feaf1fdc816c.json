{"nodes": [{"id": "dev_phase1_project_graph_projectconfig", "label": "ProjectConfig", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_project", "label": "Project", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_graph", "label": "Graph (DAG model)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The graph is a DAG (Directed Acyclic Graph). Cycles must be rejected. Edges can only connect ports of compatible types. UUIDs are used for IDs (never mutable integer indexes)."}, {"id": "dev_phase1_project_graph_node", "label": "Node", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_port", "label": "Port", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_edge", "label": "Edge", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_graph_serialization", "label": "Graph Serialization (JSON)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "UI state (selection) must NOT be stored in serialization. Position is OK to store. A schema_version field is required for future migrations."}, {"id": "dev_phase1_project_graph_graph_validator", "label": "Graph Validator", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_dfs_cycle_detection", "label": "DFS Colored Cycle Detection", "file_type": "rationale", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "3-color DFS (WHITE/GRAY/BLACK). Reaching a GRAY node means a cycle was detected. Alternative: Kahn's algorithm (topological sort via BFS using in-degree tracking)."}, {"id": "dev_phase1_project_graph_validationresult", "label": "ValidationResult", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_graphscene", "label": "GraphScene (QGraphicsScene)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scene does NOT modify the Graph model directly \u2014 it emits signals. Signal \u2192 Controller \u2192 Graph (MVC or Command pattern). For thousands of nodes use QGraphicsItem.setFlag(ItemUsesExtendedStyleOption) and Qt native culling."}, {"id": "dev_phase1_project_graph_graphview", "label": "GraphView (QGraphicsView)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_nodeitem", "label": "NodeItem (QGraphicsItem)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_edgeitem", "label": "EdgeItem (Bezier curve)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bezier curve: P0=source port, P3=dest port, P1=P0+(100,0), P2=P3-(100,0). Uses QPainterPath.cubicTo."}, {"id": "dev_phase1_project_graph_nodedefinition", "label": "NodeDefinition", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.6", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase1_project_graph_noderegistry", "label": "NodeRegistry", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.6", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Singleton (or global dict) mapping type \u2192 NodeDefinition. Allows adding custom nodes later via plugins."}, {"id": "dev_phase1_project_graph_command_pattern", "label": "Command Pattern (Undo/Redo)", "file_type": "rationale", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Command ABC with execute()/undo(). CommandHistory with stack+index. MacroCommand for multi-step operations (e.g., paste = N AddNode + M AddEdge). History limit of ~100 commands to prevent memory leaks."}, {"id": "dev_phase1_project_graph_componentdefinition", "label": "ComponentDefinition (Subgraph)", "file_type": "concept", "source_file": "docs/dev/phase1_project_graph.md", "source_location": "section 1.8", "source_url": null, "captured_at": null,