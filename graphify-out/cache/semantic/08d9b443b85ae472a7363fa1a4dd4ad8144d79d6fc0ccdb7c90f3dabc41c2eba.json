{"nodes": [{"id": "dev_phase4_live_monitoring_hookmanager", "label": "HookManager (PyTorch Hooks)", "file_type": "concept", "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hooks run in training process. Only scalar statistics sent to queue (not full tensors). Subsampling every N steps to avoid slowing training. Handles must be properly removed via handle.remove() at end of training."}, {"id": "dev_phase4_live_monitoring_ringbuffer", "label": "RingBuffer C++ (Lock-Free SPSC)", "file_type": "concept", "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Python multiprocessing.Queue has high latency and serialization overhead. A lock-free ring buffer in shared memory is much faster for scalar streaming. SPSC (Single Producer Single Consumer): trivially lock-free. Uses std::atomic with memory_order_acquire/release."}, {"id": "dev_phase4_live_monitoring_live_graph_update", "label": "Live Graph Qt Update", "file_type": "concept", "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "QTimer at 100ms reads ring buffer. Only update nodes with changed metrics. QGraphicsItem.update() is async \u2014 Qt batches repaints. Avoid allocations in update slot (reuse QColor objects)."}, {"id": "dev_phase4_live_monitoring_nodeinspector", "label": "NodeInspector (QDockWidget)", "file_type": "concept", "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Welford's online algorithm for mean/variance in a single pass. Histogram via torch.histc(tensor, bins=50) on training side, send bin counts. pyqtgraph recommended for rendering (lightweight, native Qt, real-time capable)."}, {"id": "dev_phase4_live_monitoring_visualization_panels", "label": "Visualization Panels", "file_type": "concept", "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Activation maps for Conv2d only: send first image of batch, first channels. Offer snapshot mode (on demand) vs live mode (every N steps)."}], "edges": [{"source": "dev_phase4_live_monitoring_hookmanager", "target": "dev_phase2_pytorch_training_trainingworker", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.1 \u2014 hooks run in training process", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_hookmanager", "target": "dev_phase4_live_monitoring_ringbuffer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.1 \u2014 sends to metrics_queue", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_live_graph_update", "target": "dev_phase4_live_monitoring_ringbuffer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.3", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_live_graph_update", "target": "dev_phase1_project_graph_graphscene", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.3", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_live_graph_update", "target": "dev_phase1_project_graph_nodeitem", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.3", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_nodeinspector", "target": "dev_phase1_project_graph_nodeitem", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.4", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_visualization_panels", "target": "dev_phase2_pytorch_training_run", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.5 \u2014 loss/metrics curves from run data", "weight": 1.0}, {"source": "dev_phase4_live_monitoring_ringbuffer", "target": "dev_phase2_pytorch_training_trainingmessage", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "docs/dev/phase4_live_monitoring.md", "source_location": "section 4.2 \u2014 ring buffer replaces Python Queue for metric transport", "weight": 1.0}], "hyperedges": []}
