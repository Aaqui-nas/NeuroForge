{"nodes": [{"id": "dev_phase5_remote_execution_remotehost", "label": "RemoteHost / SSHAuthConfig", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Passwords/passphrases stored in system keyring (keyring library). Configurable connection timeout (default 10s). Auto-reconnect on session expiry."}, {"id": "dev_phase5_remote_execution_remoteconnectionmanager", "label": "RemoteConnectionManager", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dev_phase5_remote_execution_file_sync", "label": "Remote File Synchronization", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses rsync via subprocess if available, falls back to paramiko SFTP. Smart sync: compute SHA256 of local files, only transfer missing or changed files. Remote venv created if needed."}, {"id": "dev_phase5_remote_execution_remotetrainingcontroller", "label": "RemoteTrainingController", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Metrics streamed from remote via SSH stdout as JSON lines. Local thread reads SSH channel line-by-line, parses JSON, updates UI."}, {"id": "dev_phase5_remote_execution_checkpoint_transfer", "label": "Remote Checkpoint Transfer", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Checkpoints saved remotely, automatically repatriated every N epochs (configurable). Stored in local object store. Optional gzip compression before transfer. Advanced: sparse diff of weights for large models."}, {"id": "dev_phase5_remote_execution_profiling", "label": "Advanced Profiling (PyTorch Profiler + pynvml)", "file_type": "concept", "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Profiling slows training: offer a separate profiling mode. Profiling traces can be very large: limit capture duration. On remote machine: run profiler, repatriate trace, visualize locally."}], "edges": [{"source": "dev_phase5_remote_execution_remoteconnectionmanager", "target": "dev_phase5_remote_execution_remotehost", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.1", "weight": 1.0}, {"source": "dev_phase5_remote_execution_file_sync", "target": "dev_phase5_remote_execution_remoteconnectionmanager", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.2", "weight": 1.0}, {"source": "dev_phase5_remote_execution_file_sync", "target": "dev_phase3_versioning_objectstore", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.2 \u2014 uses SHA256 hash-based sync like the object store", "weight": 1.0}, {"source": "dev_phase5_remote_execution_remotetrainingcontroller", "target": "dev_phase5_remote_execution_remoteconnectionmanager", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/dev/phase5_remote_execution.md", "source_location": "section 5.3", "weight": 1.0}, {"source": "dev_phase5_remote_execution_remotetrainingcontroller",